{
  "name": "jasmine-music-player",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "description": "Jasmine Music Player - Spotify-style music player built with React",
  "author": "Z1RO014011 <zhr014011@outlook.com>",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "ELECTRON=true vite build && electron-builder",
    "electron:build:all": "ELECTRON=true vite build && electron-builder --mac --win --linux"
  },
  "build": {
    "appId": "com.jasmine.musicplayer",
    "productName": "Jasmine Music Player",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "icon": "assets/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Z1RO014011"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": "zip"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "gh-pages": "^6.2.0",
    "png-to-ico": "^3.0.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.0",
    "wait-on": "^9.0.5"
  }
}
